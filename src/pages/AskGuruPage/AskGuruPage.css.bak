@import '../../styles/theme.css';

.ask-guru-page {
  min-height: 100vh;
  padding: 2rem;
  background: linear-gradient(135deg, #fffaf0 0%, #fff4e6 100%);
}

.ask-guru-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.guru-header {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  padding: 2rem;
  text-align: center;
  color: white;
}

.guru-header h1 {
  font-size: 2.5rem;
  margin-bottom: 0.5rem;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
}

.guru-subtitle {
  font-size: 1.1rem;
  opacity: 0.95;
}

.guru-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 2rem;
  display: grid;
  grid-template-columns: 1fr 350px;
  gap: 2rem;
  height: calc(100vh - 200px);
}

.chat-section {
  background: white;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.messages-container {
  flex-grow: 1;
  overflow-y: auto;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.message {
  display: flex;
  gap: 1rem;
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message.user {
  flex-direction: row-reverse;
}

.message-avatar {
  font-size: 2.5rem;
  flex-shrink: 0;
}

.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.message.guru .message-content {
  background: #f0f0f0;
  padding: 1rem;
  border-radius: 15px 15px 15px 0;
}

.message.user .message-content {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  padding: 1rem;
  border-radius: 15px 15px 0 15px;
}

.message.user .message-text {
  color: white;
}

.message-text {
  line-height: 1.6;
  white-space: pre-wrap;
  color: #333;
}

.message.user .message-time {
  color: rgba(255, 255, 255, 0.8);
}

.scripture-reference {
  background: rgba(255, 107, 107, 0.1);
  padding: 0.5rem;
  border-radius: 8px;
  font-size: 0.9rem;
  color: #FF6B6B;
  font-style: italic;
}

.message-time {
  font-size: 0.75rem;
  color: #999;
  align-self: flex-end;
}

.typing-indicator {
  display: flex;
  gap: 0.3rem;
  padding: 1rem;
}

.typing-indicator span {
  width: 8px;
  height: 8px;
  background: #999;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out;
}

.typing-indicator span:nth-child(1) {
  animation-delay: -0.32s;
}

.typing-indicator span:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.input-container {
  padding: 1.5rem;
  border-top: 1px solid #eee;
  display: flex;
  gap: 1rem;
}

.input-container textarea {
  flex-grow: 1;
  border: 2px solid #eee;
  border-radius: 12px;
  padding: 1rem;
  font-size: 1rem;
  font-family: inherit;
  resize: none;
  transition: border-color 0.3s ease;
}

.input-container textarea:focus {
  outline: none;
  border-color: #FF6B6B;
}

.send-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: white;
  border: none;
  padding: 0 2rem;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.send-btn:hover {
  transform: scale(1.05);
}

.sidebar-section {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  overflow-y: auto;
}

.suggested-topics,
.guru-info {
  background: white;
  border-radius: 20px;
  padding: 1.5rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.suggested-topics h3,
.guru-info h3 {
  color: #FF6B6B;
  font-size: 1.3rem;
  margin-bottom: 1rem;
}

.topics-grid {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.topic-btn {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  background: #f9f9f9;
  border: 2px solid #eee;
  padding: 1rem;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: left;
}

.topic-btn:hover {
  background: #fff;
  border-color: #FF6B6B;
  transform: translateX(5px);
}

.topic-icon {
  font-size: 1.8rem;
}

.topic-text {
  flex-grow: 1;
}

.topic-title {
  color: #333;
  font-weight: 600;
  font-size: 0.95rem;
}

.topic-category {
  color: #999;
  font-size: 0.8rem;
  margin-top: 0.2rem;
}

.guru-info p {
  color: #666;
  line-height: 1.6;
  margin-bottom: 1rem;
}

.guru-info ul {
  list-style: none;
  padding: 0;
}

.guru-info li {
  color: #666;
  padding: 0.5rem 0;
  padding-left: 1.5rem;
  position: relative;
}

.guru-info li::before {
  content: '•';
  color: #FF6B6B;
  font-weight: bold;
  position: absolute;
  left: 0;
}

@media (max-width: 1024px) {
  .guru-container {
    grid-template-columns: 1fr;
    height: auto;
  }

  .chat-section {
    height: 600px;
  }

  .sidebar-section {
    overflow-y: visible;
  }
}

@media (max-width: 768px) {
  .guru-header h1 {
    font-size: 2rem;
  }

  .guru-container {
    padding: 1rem;
  }

  .message-content {
    max-width: 85%;
  }

  .input-container {
    flex-direction: column;
  }

  .send-btn {
    width: 100%;
  }
}
