@import '../../styles/theme.css';

.panchangam-page {
  padding: 40px 20px;
  max-width: 1000px;
  margin: 0 auto;
  min-height: 80vh;
}

.panchangam-header-section {
  text-align: center;
  margin-bottom: 40px;
}

.panchangam-main-title {
  color: var(--accent-primary);
  font-family: 'Lato', sans-serif;
  font-size: 2.5rem;
  font-weight: 700;
  margin-bottom: 10px;
}

.panchangam-meta {
  display: flex;
  justify-content: center;
  gap: 20px;
  font-family: 'Lato', sans-serif;
  font-size: 1.1rem;
  color: var(--text-primary);
}

.panchangam-meta-item {
  background: var(--card-background);
  padding: 5px 15px;
  border-radius: 20px;
  box-shadow: var(--card-shadow);
}

.panchangam-content {
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.panchangam-section {
  background: var(--card-background);
  padding: 25px;
  border-radius: 12px;
  box-shadow: var(--card-shadow);
}

.panchangam-section-title {
  color: var(--accent-primary);
  font-family: 'Lato', sans-serif;
  font-size: 1.5rem;
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--accent-secondary);
}

.panchangam-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 15px 30px;
}

.panchangam-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 8px 0;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

.panchangam-row:last-child {
  border-bottom: none;
}

.panchangam-label {
  font-family: 'Lato', sans-serif;
  font-weight: 600;
  color: var(--text-primary);
  font-size: 1rem;
}

.panchangam-value {
  font-family: 'Lato', sans-serif;
  color: var(--text-primary);
  font-size: 1rem;
  text-align: right;
}

.panchangam-subtext {
  display: block;
  font-size: 0.8rem;
  color: #666;
  margin-top: 2px;
}

/* Specific Section Styles */
.panchangam-columns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
}

@media (max-width: 768px) {
  .panchangam-columns {
    grid-template-columns: 1fr;
  }
}

.panchangam-section.auspicious .panchangam-section-title {
  color: #2e7d32; /* Greenish for auspicious */
  border-bottom-color: #a5d6a7;
}

.panchangam-section.inauspicious .panchangam-section-title {
  color: #c62828; /* Reddish for inauspicious */
  border-bottom-color: #ef9a9a;
}

.panchangam-page-loading,
.panchangam-page-error {
  text-align: center;
  padding: 50px;
  font-size: 1.5rem;
  color: var(--text-primary);
  font-family: 'Lato', sans-serif;
}

.panchangam-page-error {
  color: #d32f2f;
}
