@import '../../styles/theme.css';

.gita-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  padding: 40px 20px;
}

.gita-container {
  max-width: 1200px;
  margin: 0 auto;
  background: white;
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  padding: 40px;
}

.gita-hero {
  
  min-height: 100vh;
  text-align: center;
  margin-bottom: 30px;
}

.gita-title {
  font-size: 3rem;
  color: var(--accent-primary);
  margin-bottom: 15px;
  font-weight: 700;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
}

.gita-summary {
  font-size: 1.2rem;
  color: var(--text-secondary);
  line-height: 1.6;
  max-width: 800px;
  margin: 0 auto;
}

.gita-image-container {
  text-align: center;
  margin: 30px 0;
}

.gita-image {
  max-width: 100%;
  height: auto;
  border-radius: 15px;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  max-height: 400px;
  object-fit: cover;
}

.gita-intro {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 30px;
  border-radius: 15px;
  margin: 30px 0;
}

.gita-intro h2 {
  margin-top: 0;
  font-size: 1.8rem;
}

.gita-intro p {
  line-height: 1.8;
  font-size: 1.1rem;
}

.features-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
  justify-content: center;
  margin: 30px 0;
}

.feature-badge {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  padding: 10px 20px;
  border-radius: 25px;
  font-weight: 600;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

.chapters-section {
  margin: 40px 0;
}

.chapters-section h2 {
  font-size: 2rem;
  color: var(--text-primary);
  margin-bottom: 25px;
  text-align: center;
}

.chapters-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

.chapter-card {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  border-radius: 15px;
  padding: 20px;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.chapter-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  border-color: var(--accent-primary);
}

.chapter-card.expanded {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.chapter-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.chapter-num {
  font-weight: 700;
  color: var(--accent-primary);
  font-size: 0.9rem;
}

.iconic-star {
  font-size: 1.5rem;
}

.conclusion-badge {
  font-size: 1.2rem;
}

.chapter-card-title {
  font-size: 1.1rem;
  color: var(--text-primary);
  margin: 10px 0;
  line-height: 1.4;
}

.chapter-card-verses {
  color: var(--text-tertiary);
  font-size: 0.9rem;
  margin: 5px 0;
}

.chapter-card-expanded {
  margin-top: 15px;
  padding-top: 15px;
  border-top: 2px solid rgba(255, 107, 53, 0.3);
}

.chapter-card-summary {
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 15px;
}

.chapter-key-teachings {
  margin: 15px 0;
  color: var(--text-primary);
}

.chapter-key-teachings ul {
  margin: 10px 0;
  padding-left: 20px;
}

.chapter-key-teachings li {
  margin: 5px 0;
  line-height: 1.5;
}

.read-chapter-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: 25px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 100%;
  margin-top: 10px;
}

.read-chapter-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
}

.back-to-chapters-btn {
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-primary) 100%);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: 25px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-bottom: 30px;
}

.back-to-chapters-btn:hover {
  transform: translateX(-5px);
  box-shadow: 0 5px 15px rgba(255, 107, 53, 0.4);
}

.chapter-detail {
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.chapter-header {
  text-align: center;
  margin-bottom: 40px;
  padding: 30px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 15px;
  color: white;
}

.chapter-number {
  font-size: 1rem;
  font-weight: 600;
  opacity: 0.9;
}

.chapter-title {
  font-size: 2.5rem;
  margin: 10px 0;
}

.chapter-verses {
  font-size: 1.1rem;
  opacity: 0.9;
}

.chapter-illustration {
  text-align: center;
  margin: 30px 0;
}

.chapter-illustration img {
  max-width: 100%;
  height: auto;
  border-radius: 15px;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  max-height: 500px;
  object-fit: cover;
}

.chapter-summary-section,
.key-teachings-section,
.audio-section,
.verses-section {
  margin: 30px 0;
  padding: 25px;
  background: var(--neutral-300);
  border-radius: 15px;
}

.chapter-summary-section h2,
.key-teachings-section h2,
.audio-section h2,
.verses-section h2 {
  color: var(--accent-primary);
  margin-top: 0;
  font-size: 1.6rem;
}

.teachings-list {
  list-style: none;
  padding: 0;
}

.teachings-list li {
  padding: 12px 0;
  padding-left: 30px;
  position: relative;
  line-height: 1.6;
  border-bottom: 1px solid var(--neutral-200);
}

.teachings-list li:last-child {
  border-bottom: none;
}

.teachings-list li::before {
  content: '✨';
  position: absolute;
  left: 0;
  font-size: 1.2rem;
}

.verses-section {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.verse-card {
  background: white;
  padding: 20px;
  border-radius: 10px;
  margin: 15px 0;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

.verse-number {
  font-weight: 700;
  color: var(--accent-primary);
  margin-bottom: 10px;
}

.verse-sanskrit {
  font-size: 1.3rem;
  color: var(--text-primary);
  margin: 10px 0;
  font-weight: 600;
  line-height: 1.8;
}

.verse-transliteration {
  font-style: italic;
  color: var(--text-tertiary);
  margin: 10px 0;
  line-height: 1.6;
}

.verse-translation {
  color: var(--text-primary);
  margin: 15px 0;
  line-height: 1.7;
  font-size: 1.05rem;
}

.iconic-badge {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  padding: 15px 25px;
  border-radius: 15px;
  text-align: center;
  font-weight: 600;
  margin: 30px 0;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
}

.back-link {
  display: inline-block;
  margin-top: 40px;
  color: var(--accent-primary);
  text-decoration: none;
  font-weight: 600;
  font-size: 1.1rem;
  transition: all 0.3s ease;
}

.back-link:hover {
  color: var(--accent-primary);
  transform: translateX(-5px);
}

/* Responsive Design */
@media (max-width: 768px) {
  .gita-container {
    padding: 20px;
  }

  .gita-title {
    font-size: 2rem;
  }

  .chapters-grid {
    grid-template-columns: 1fr;
  }

  .chapter-title {
    font-size: 1.8rem;
  }
}
