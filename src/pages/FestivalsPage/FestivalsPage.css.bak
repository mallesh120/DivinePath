@import '../../styles/theme.css';

.festivals-page {
  min-height: 100vh;
  padding: 2rem;
  background: linear-gradient(135deg, var(--parchment-light) 0%, var(--parchment-light) 100%);
}

.festivals-page {
  max-width: 1400px;
  margin: 0 auto;
  padding: 30px 20px;
}

.festivals-page-header {
  text-align: center;
  margin-bottom: 40px;
}

.festivals-page-title {
  font-size: 2.5rem;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 10px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.festivals-page-subtitle {
  font-size: 1.1rem;
  color: #7f8c8d;
  max-width: 700px;
  margin: 0 auto 20px;
  line-height: 1.6;
}

/* Location Display & Picker */
.location-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin: 20px auto;
  padding: 12px 20px;
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  border-radius: 12px;
  max-width: 500px;
}

.location-icon {
  font-size: 1.2rem;
}

.location-text {
  font-size: 1rem;
  color: #2c3e50;
}

.change-location-btn {
  padding: 8px 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.9rem;
  font-weight: 600;
  transition: transform 0.2s;
}

.change-location-btn:hover {
  transform: scale(1.05);
}

.location-picker {
  background: white;
  border: 2px solid #667eea;
  border-radius: 12px;
  padding: 25px;
  margin: 20px auto;
  max-width: 900px;
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.2);
  max-height: 600px;
  overflow-y: auto;
}

.location-picker h3 {
  text-align: center;
  color: #2c3e50;
  margin-bottom: 10px;
  font-size: 1.4rem;
}

.location-picker-subtitle {
  text-align: center;
  color: #7f8c8d;
  font-size: 0.95rem;
  margin-bottom: 20px;
}

.city-region-group {
  margin-bottom: 25px;
}

.region-heading {
  color: #667eea;
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid #667eea30;
}

.city-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 10px;
}

.city-option {
  padding: 12px;
  background: var(--neutral-300);
  border: 2px solid var(--neutral-200);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  font-weight: 600;
  color: #2c3e50;
}

.city-option:hover {
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  border-color: #667eea;
  transform: translateY(-2px);
}

.city-option.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-color: #667eea;
}

.city-country {
  font-size: 0.8rem;
  font-weight: 400;
  opacity: 0.8;
}

.festivals-filters {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
  margin-bottom: 30px;
  justify-content: center;
  align-items: center;
}

.festival-filter-label {
  font-weight: 600;
  color: #2c3e50;
  font-size: 1rem;
}

.festival-filter-select {
  padding: 10px 15px;
  border: 2px solid var(--neutral-200);
  border-radius: 8px;
  font-size: 1rem;
  color: #2c3e50;
  background-color: white;
  cursor: pointer;
  transition: all 0.3s ease;
  min-width: 180px;
}

.festival-filter-select:hover {
  border-color: #667eea;
}

.festival-filter-select:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.festivals-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  gap: 25px;
  margin-bottom: 40px;
}

.festivals-empty {
  text-align: center;
  padding: 60px 20px;
  color: #7f8c8d;
}

.festivals-empty-icon {
  font-size: 4rem;
  margin-bottom: 20px;
}

.festivals-empty-text {
  font-size: 1.2rem;
  color: #2c3e50;
  margin-bottom: 10px;
}

.festivals-empty-subtext {
  font-size: 1rem;
  color: #7f8c8d;
}

.festivals-count {
  text-align: center;
  margin-bottom: 20px;
  font-size: 1rem;
  color: #7f8c8d;
}

.festivals-count-number {
  font-weight: 700;
  color: #667eea;
}

/* Responsive design */
@media (max-width: 768px) {
  .festivals-page-title {
    font-size: 2rem;
  }

  .festivals-filters {
    flex-direction: column;
    align-items: stretch;
  }

  .festival-filter-select {
    width: 100%;
  }

  .festivals-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 480px) {
  .festivals-page {
    padding: 20px 15px;
  }

  .festivals-page-title {
    font-size: 1.75rem;
  }

  .festivals-page-subtitle {
    font-size: 1rem;
  }
}

/* View Mode Toggle */
.view-mode-toggle {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin-bottom: 30px;
}

.view-mode-btn {
  padding: 12px 30px;
  border: 2px solid var(--neutral-200);
  background: white;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.view-mode-btn:hover {
  border-color: var(--accent-primary);
  color: var(--accent-primary);
}

.view-mode-btn.active {
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-primary) 100%);
  color: white;
  border-color: var(--accent-primary);
}

/* Calendar View Styles */
.calendar-container {
  max-width: 1200px;
  margin: 0 auto;
  background: white;
  border-radius: 15px;
  padding: 30px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  gap: 20px;
}

.calendar-header-title {
  display: flex;
  gap: 10px;
  align-items: center;
}

.calendar-month-select,
.calendar-year-select {
  padding: 10px 15px;
  font-size: 1.1rem;
  font-weight: 600;
  border: 2px solid var(--neutral-200);
  border-radius: 8px;
  background: white;
  cursor: pointer;
  transition: border-color 0.3s ease;
}

.calendar-month-select:hover,
.calendar-year-select:hover {
  border-color: var(--accent-primary);
}

.calendar-nav-btn {
  padding: 10px 20px;
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-primary) 100%);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.3s ease;
}

.calendar-nav-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
}

/* Calendar Legend */
.calendar-legend {
  background: linear-gradient(135deg, var(--card-bg) 0%, #f8f9ff 100%);
  border: 2px solid #667eea;
  border-radius: 15px;
  padding: 25px;
  margin-bottom: 25px;
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.1);
}

.legend-title {
  color: #2c3e50;
  font-size: 1.4rem;
  margin-bottom: 20px;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

.legend-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}

.legend-section {
  background: white;
  padding: 15px;
  border-radius: 10px;
  border: 1px solid var(--neutral-200);
}

.legend-section h4 {
  color: #667eea;
  font-size: 1rem;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid #667eea;
}

.legend-items {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.9rem;
  color: #2c3e50;
}

.legend-icon {
  font-size: 1.3rem;
  min-width: 30px;
  text-align: center;
}

.legend-icon.orange-dot {
  color: var(--accent-primary);
  font-size: 2rem;
  font-weight: bold;
}

.legend-color {
  padding: 4px 12px;
  border-radius: 5px;
  font-weight: 600;
  min-width: 80px;
  text-align: center;
  font-size: 0.85rem;
}

.legend-color.tithi-color {
  background: #667eea;
  color: white;
}

.legend-color.nakshatra-color {
  background: #764ba2;
  color: white;
  font-style: italic;
}

.legend-color.yoga-color {
  background: #43a047;
  color: white;
}

.legend-box {
  width: 30px;
  height: 30px;
  border-radius: 5px;
  border: 2px solid;
}

.legend-box.festival-box {
  background: linear-gradient(135deg, var(--card-bg)8f0 0%, #ffe4cc 100%);
  border-color: var(--accent-primary);
}

.legend-box.today-box {
  background: linear-gradient(135deg, var(--card-bg)3e0 0%, #ffe0b2 100%);
  border-color: var(--accent-primary);
}

.legend-box.auspicious-box {
  background: white;
  border-color: #4caf50;
  box-shadow: 0 0 8px rgba(76, 175, 80, 0.4);
}

.legend-text {
  flex: 1;
  line-height: 1.4;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10px;
  margin-bottom: 10px;
}

.calendar-weekday {
  text-align: center;
  font-weight: 700;
  color: #2c3e50;
  padding: 10px;
  background: linear-gradient(135deg, var(--neutral-300) 0%, #e9ecef 100%);
  border-radius: 8px;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10px;
}

.calendar-day {
  aspect-ratio: 1;
  border: 2px solid var(--neutral-200);
  border-radius: 10px;
  padding: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  cursor: pointer;
  transition: all 0.3s ease;
  background: white;
  position: relative;
  overflow: hidden;
}

.calendar-day.empty {
  border: none;
  background: transparent;
  cursor: default;
}

.calendar-day:not(.empty):hover {
  border-color: var(--accent-primary);
  transform: translateY(-3px);
  box-shadow: 0 4px 15px rgba(255, 107, 53, 0.2);
}

.calendar-day.today {
  background: linear-gradient(135deg, var(--card-bg)3e0 0%, #ffe0b2 100%);
  border-color: var(--accent-primary);
  font-weight: 700;
}

.calendar-day.has-festival {
  background: linear-gradient(135deg, var(--card-bg)8f0 0%, #ffe4cc 100%);
  border-color: var(--accent-primary);
}

/* Special day styles */
.calendar-day.special-ekadashi {
  border-color: #9c27b0;
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

.calendar-day.special-purnima {
  border-color: var(--gold-accent);
  background: linear-gradient(135deg, var(--card-bg)de7 0%, var(--card-bg)9c4 100%);
}

.calendar-day.special-amavasya {
  border-color: #424242;
  background: linear-gradient(135deg, #f5f5f5 0%, var(--neutral-200) 100%);
}

.calendar-day.special-pradosham {
  border-color: #ff5722;
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
}

.calendar-day.special-chaturthi {
  border-color: #ff9800;
  background: linear-gradient(135deg, var(--card-bg)3e0 0%, #ffe0b2 100%);
}

/* Auspiciousness styles */
.calendar-day.highly-auspicious {
  box-shadow: 0 0 10px rgba(76, 175, 80, 0.3);
}

.calendar-day.low-auspicious {
  opacity: 0.9;
}

/* Calendar day header with number and badge */
.calendar-day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  margin-bottom: 3px;
}

.calendar-day-number {
  font-size: 1rem;
  font-weight: 600;
  color: #2c3e50;
}

.special-badge {
  font-size: 1rem;
  line-height: 1;
}

/* Moon phase indicator */
.moon-phase-indicator {
  margin: 3px 0;
}

.moon-icon {
  font-size: 1.2rem;
  line-height: 1;
  border-radius: 50%;
  padding: 2px;
}

/* Panchang (Hindu Calendar) Info */
.calendar-panchang-info {
  font-size: 0.6rem;
  color: #5a5a5a;
  text-align: center;
  line-height: 1.2;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  gap: 1px;
  margin: 2px 0;
  width: 100%;
}

.panchang-tithi,
.panchang-nakshatra,
.panchang-yoga {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
  padding: 1px 2px;
}

.panchang-tithi {
  font-weight: 600;
  color: #667eea;
}

.panchang-nakshatra {
  color: #764ba2;
  font-style: italic;
}

.panchang-yoga {
  color: #43a047;
  font-size: 0.55rem;
}

/* Auspiciousness rating */
.auspiciousness-rating {
  font-size: 0.6rem;
  margin: 2px 0;
  line-height: 1;
}

.calendar-day-festivals {
  display: flex;
  gap: 3px;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  margin-top: 2px;
}

.calendar-festival-dot {
  width: 8px;
  height: 8px;
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-primary) 100%);
  border-radius: 50%;
  font-size: 0;
}

.calendar-festival-more {
  font-size: 0.7rem;
  color: var(--accent-primary);
  font-weight: 700;
  margin-left: 2px;
}

.calendar-festival-details {
  margin-top: 30px;
  padding: 25px;
  background: linear-gradient(135deg, var(--card-bg)8f0 0%, #ffe4cc 100%);
  border-radius: 15px;
  border: 2px solid var(--accent-primary);
  max-height: 80vh;
  overflow-y: auto;
}

.calendar-festival-details h3 {
  color: #2c3e50;
  margin-bottom: 20px;
  font-size: 1.5rem;
  text-align: center;
}

.calendar-festival-details h4 {
  color: #667eea;
  margin: 20px 0 15px 0;
  font-size: 1.1rem;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* Day Overview Section */
.day-overview-section {
  margin-bottom: 25px;
  padding: 20px;
  background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%);
  border-radius: 12px;
  border: 2px solid #5c6bc0;
}

.auspiciousness-display {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 15px;
  flex-wrap: wrap;
}

.auspiciousness-label {
  font-weight: 700;
  color: #2c3e50;
  font-size: 1.1rem;
}

.auspiciousness-stars {
  font-size: 1.3rem;
  line-height: 1;
}

.auspiciousness-text {
  padding: 5px 15px;
  background: white;
  border-radius: 20px;
  font-weight: 600;
  color: #667eea;
}

.best-for-section {
  padding: 12px;
  background: white;
  border-radius: 8px;
  margin-bottom: 12px;
}

.best-for-section strong {
  color: #667eea;
  margin-right: 8px;
}

.special-indicators {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.special-tag {
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.9rem;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 5px;
}

.ekadashi-tag {
  background: linear-gradient(135deg, #9c27b0 0%, #ba68c8 100%);
  color: white;
}

.purnima-tag {
  background: linear-gradient(135deg, var(--gold-accent) 0%, #ffed4e 100%);
  color: var(--text-primary);
}

.amavasya-tag {
  background: linear-gradient(135deg, #424242 0%, #757575 100%);
  color: white;
}

.pradosham-tag {
  background: linear-gradient(135deg, #ff5722 0%, #ff8a65 100%);
  color: white;
}

.chaturthi-tag {
  background: linear-gradient(135deg, #ff9800 0%, #ffb74d 100%);
  color: white;
}

.ashtami-tag {
  background: linear-gradient(135deg, #00bcd4 0%, #4dd0e1 100%);
  color: white;
}

/* Panchang Details Section */
.panchang-details-section {
  margin-bottom: 25px;
  padding: 20px;
  background: white;
  border-radius: 12px;
  border: 2px solid #667eea;
}

.panchang-details-section h4 {
  margin-top: 0;
  margin-bottom: 15px;
}

.panchang-details-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px;
}

.panchang-detail-item {
  padding: 12px;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f2ff 100%);
  border-radius: 8px;
  border-left: 3px solid #667eea;
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.panchang-detail-item.time-item {
  border-left-color: #43a047;
}

.panchang-detail-item.warning {
  border-left-color: #f44336;
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
}

.panchang-detail-item strong {
  color: #667eea;
  display: block;
  font-size: 0.9rem;
}

.panchang-detail-item span {
  color: #2c3e50;
  font-size: 1rem;
}

.time-warning {
  margin-top: 10px;
  padding: 10px;
  background: var(--card-bg)3e0;
  border-radius: 8px;
  border-left: 3px solid #ff9800;
}

.time-warning small {
  color: #e65100;
  font-weight: 600;
}

/* Moon Phase Visual */
.moon-phase-visual {
  margin-top: 15px;
  text-align: center;
}

.moon-display {
  display: inline-block;
  font-size: 3rem;
  padding: 15px;
  border-radius: 50%;
  background-clip: text;
  -webkit-background-clip: text;
  filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5));
}

.panchang-detail-item strong {
  color: #667eea;
  display: block;
  margin-bottom: 5px;
  font-size: 0.9rem;
}

.calendar-festival-list {
  display: flex;
  flex-direction: column;
  gap: 15px;
  margin-bottom: 20px;
}

.calendar-festival-item {
  padding: 15px;
  background: white;
  border-radius: 10px;
  border-left: 4px solid var(--accent-primary);
}

.calendar-festival-item strong {
  display: block;
  color: #2c3e50;
  margin-bottom: 5px;
  font-size: 1.1rem;
}

.calendar-festival-item p {
  color: #7f8c8d;
  margin: 0;
  line-height: 1.5;
}

.calendar-close-details {
  padding: 10px 25px;
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-primary) 100%);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.2s ease;
}

.calendar-close-details:hover {
  transform: translateY(-2px);
}

@media (max-width: 768px) {
  .calendar-container {
    padding: 15px;
  }

  .calendar-header {
    flex-direction: column;
    gap: 15px;
  }

  .calendar-nav-btn {
    padding: 8px 15px;
    font-size: 0.9rem;
  }

  .calendar-day-number {
    font-size: 0.85rem;
  }

  .calendar-weekday {
    font-size: 0.75rem;
    padding: 5px;
  }
  
  .calendar-panchang-info {
    font-size: 0.55rem;
  }
  
  .panchang-yoga {
    display: none; /* Hide yoga on mobile for space */
  }
  
  .auspiciousness-rating {
    font-size: 0.5rem;
  }
  
  .moon-icon {
    font-size: 1rem;
  }
  
  .special-badge {
    font-size: 0.85rem;
  }
  
  /* Legend responsive */
  .calendar-legend {
    padding: 15px;
  }
  
  .legend-title {
    font-size: 1.2rem;
  }
  
  .legend-grid {
    grid-template-columns: 1fr;
    gap: 15px;
  }
  
  .legend-section {
    padding: 12px;
  }
  
  .legend-section h4 {
    font-size: 0.95rem;
  }
  
  .legend-item {
    font-size: 0.85rem;
    gap: 8px;
  }
  
  .legend-icon {
    font-size: 1.1rem;
    min-width: 25px;
  }
  
  .calendar-festival-details {
    padding: 15px;
    max-height: 70vh;
  }
  
  .panchang-details-grid {
    grid-template-columns: 1fr;
  }
  
  .auspiciousness-display {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .special-indicators {
    flex-direction: column;
  }
  
  .calendar-festival-details h3 {
    font-size: 1.2rem;
  }
  
  .calendar-festival-details h4 {
    font-size: 1rem;
  }
}

@media (max-width: 480px) {
  .calendar-day {
    padding: 4px;
  }
  
  .calendar-day-number {
    font-size: 0.75rem;
  }
  
  .calendar-panchang-info {
    font-size: 0.5rem;
    gap: 1px;
  }
  
  .auspiciousness-rating {
    display: none; /* Hide stars on very small screens */
  }
  
  .panchang-nakshatra {
    display: none; /* Show only tithi on very small screens */
  }
}
