@import '../../styles/theme.css';

.muhurta-finder-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 2rem;
}

.muhurta-header {
  text-align: center;
  color: white;
  margin-bottom: 2rem;
}

.muhurta-header h1 {
  font-size: 3rem;
  margin-bottom: 0.5rem;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
}

.muhurta-subtitle {
  font-size: 1.2rem;
  opacity: 0.95;
}

.muhurta-info-card {
  background: white;
  border-radius: 15px;
  padding: 2rem;
  margin-bottom: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.muhurta-info-card h3 {
  color: #667eea;
  font-size: 1.8rem;
  margin-bottom: 1rem;
}

.muhurta-info-card p {
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 1.5rem;
}

.muhurta-factors {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
}

.factor {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 10px;
  color: white;
  text-align: center;
}

.factor-icon {
  font-size: 2rem;
  margin-bottom: 0.5rem;
}

.factor-name {
  font-weight: bold;
  font-size: 1.1rem;
  margin-bottom: 0.3rem;
}

.factor-desc {
  font-size: 0.9rem;
  opacity: 0.9;
}

.info-close-btn {
  width: 100%;
  padding: 1rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 1.1rem;
  font-weight: bold;
  cursor: pointer;
  transition: transform 0.2s;
}

.info-close-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
}

.event-selection {
  background: white;
  border-radius: 15px;
  padding: 2rem;
  margin-bottom: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.event-selection h2 {
  color: #667eea;
  margin-bottom: 1.5rem;
  text-align: center;
}

.event-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
}

.event-card {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s;
  border: 3px solid transparent;
}

.event-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
}

.event-card.selected {
  border-color: #667eea;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.event-icon {
  font-size: 3rem;
  margin-bottom: 1rem;
}

.event-card h3 {
  font-size: 1.3rem;
  margin-bottom: 0.5rem;
}

.event-card p {
  font-size: 0.9rem;
  opacity: 0.8;
}

.event-details-section {
  background: white;
  border-radius: 15px;
  padding: 2rem;
  margin-bottom: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.event-info h2 {
  color: #667eea;
  margin-bottom: 1rem;
}

.event-meta {
  color: var(--text-tertiary);
  margin-bottom: 1.5rem;
  font-size: 1.1rem;
}

.considerations h4 {
  color: var(--text-primary);
  margin-bottom: 0.8rem;
}

.considerations ul {
  list-style: none;
  padding-left: 0;
}

.considerations li {
  padding: 0.5rem 0;
  padding-left: 1.5rem;
  position: relative;
  color: var(--text-secondary);
}

.considerations li::before {
  content: "▸";
  position: absolute;
  left: 0;
  color: #667eea;
  font-weight: bold;
}

.loading-state,
.error-state {
  text-align: center;
  padding: 3rem;
  color: var(--text-tertiary);
}

.spinner {
  border: 4px solid #f3f3f3;
  border-top: 4px solid #667eea;
  border-radius: 50%;
  width: 50px;
  height: 50px;
  animation: spin 1s linear infinite;
  margin: 0 auto 1rem;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.recommendation-card {
  margin-top: 2rem;
  border-top: 2px solid #eee;
  padding-top: 2rem;
}

.recommendation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.recommendation-header h3 {
  color: #667eea;
  font-size: 1.8rem;
}

.date-info {
  color: var(--text-tertiary);
  font-size: 1.1rem;
}

.status-badge {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem;
  border-radius: 12px;
  color: white;
  margin-bottom: 2rem;
  font-size: 1.2rem;
  font-weight: bold;
}

.status-icon {
  font-size: 2rem;
}

.status-score {
  font-size: 1.5rem;
  font-weight: bold;
}

.panchangam-details {
  background: #f5f7fa;
  border-radius: 12px;
  padding: 1.5rem;
  margin-bottom: 2rem;
}

.panchangam-details h4 {
  color: #667eea;
  margin-bottom: 1rem;
}

.panchangam-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.pancha-item {
  display: flex;
  justify-content: space-between;
  padding: 0.8rem;
  background: white;
  border-radius: 8px;
}

.pancha-label {
  font-weight: bold;
  color: var(--text-tertiary);
}

.pancha-value {
  color: var(--text-primary);
}

.factors-section {
  margin-bottom: 2rem;
  padding: 1.5rem;
  border-radius: 12px;
}

.factors-section.favorable {
  background: #e8f5e9;
  border-left: 4px solid #4CAF50;
}

.factors-section.unfavorable {
  background: var(--card-bg)3e0;
  border-left: 4px solid #FF9800;
}

.factors-section h4 {
  margin-bottom: 1rem;
  color: var(--text-primary);
}

.factors-section ul {
  list-style: none;
  padding-left: 0;
}

.factors-section li {
  padding: 0.5rem 0;
  padding-left: 1.5rem;
  position: relative;
  color: var(--text-secondary);
}

.factors-section.favorable li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: #4CAF50;
  font-weight: bold;
}

.factors-section.unfavorable li::before {
  content: "!";
  position: absolute;
  left: 0;
  color: #FF9800;
  font-weight: bold;
}

.recommendations-section {
  background: #e3f2fd;
  border-radius: 12px;
  padding: 1.5rem;
  margin-bottom: 2rem;
  border-left: 4px solid #2196F3;
}

.recommendations-section h4 {
  color: #1976D2;
  margin-bottom: 1rem;
}

.recommendations-section ul {
  list-style: none;
  padding-left: 0;
}

.recommendations-section li {
  padding: 0.8rem 0;
  padding-left: 1.5rem;
  position: relative;
  color: var(--text-secondary);
  line-height: 1.6;
}

.recommendations-section li::before {
  content: "➤";
  position: absolute;
  left: 0;
  color: #2196F3;
  font-weight: bold;
}

.alternative-dates {
  background: #f5f5f5;
  border-radius: 12px;
  padding: 1.5rem;
}

.alternative-dates h4 {
  color: #667eea;
  margin-bottom: 0.8rem;
}

.alternative-dates p {
  color: var(--text-tertiary);
  margin-bottom: 1.5rem;
  line-height: 1.6;
}

.tips h5 {
  color: var(--text-primary);
  margin-bottom: 0.8rem;
}

.tips ul {
  list-style: none;
  padding-left: 0;
}

.tips li {
  padding: 0.5rem 0;
  padding-left: 1.5rem;
  position: relative;
  color: var(--text-secondary);
}

.tips li::before {
  content: "•";
  position: absolute;
  left: 0;
  color: #667eea;
  font-size: 1.5rem;
  line-height: 1;
}

.muhurta-footer {
  background: white;
  border-radius: 15px;
  padding: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.disclaimer {
  background: var(--card-bg)3cd;
  border-left: 4px solid #ffc107;
  border-radius: 8px;
  padding: 1.5rem;
  margin-bottom: 2rem;
}

.disclaimer h4 {
  color: #856404;
  margin-bottom: 0.8rem;
}

.disclaimer p {
  color: #856404;
  line-height: 1.8;
  margin: 0;
}

.back-button {
  display: inline-block;
  padding: 1rem 2rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  text-decoration: none;
  border-radius: 8px;
  font-weight: bold;
  transition: transform 0.2s;
}

.back-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
}

/* Responsive Design */
@media (max-width: 768px) {
  .muhurta-finder-page {
    padding: 1rem;
  }

  .muhurta-header h1 {
    font-size: 2rem;
  }

  .muhurta-subtitle {
    font-size: 1rem;
  }

  .event-grid {
    grid-template-columns: 1fr;
  }

  .panchangam-grid {
    grid-template-columns: 1fr;
  }

  .recommendation-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .status-badge {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }
}

/* User Details Form */
.muhurta-calculator-form {
  background: white;
  border-radius: 15px;
  padding: 2rem;
  margin: 2rem 0;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
}

.muhurta-calculator-form h3 {
  color: #667eea;
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}

.form-subtitle {
  color: var(--text-tertiary);
  font-size: 0.95rem;
  margin-bottom: 1.5rem;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.form-group {
  display: flex;
  flex-direction: column;
}

.form-group label {
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
  font-size: 0.95rem;
}

.form-group input {
  padding: 0.75rem;
  border: 2px solid var(--neutral-200);
  border-radius: 8px;
  font-size: 1rem;
  transition: border-color 0.3s;
}

.form-group input:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.form-group small {
  color: var(--text-tertiary);
  font-size: 0.85rem;
  margin-top: 0.25rem;
}

.calculate-button {
  width: 100%;
  padding: 1rem 2rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 1.1rem;
  font-weight: bold;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: transform 0.2s, box-shadow 0.2s;
}

.calculate-button:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
}

.calculate-button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.button-icon {
  font-size: 1.3rem;
}

/* Time Windows Section */
.time-windows-section {
  background: #f8f9ff;
  border-radius: 12px;
  padding: 1.5rem;
  margin: 2rem 0;
}

.time-windows-section h4 {
  color: #667eea;
  font-size: 1.3rem;
  margin-bottom: 0.5rem;
}

.time-windows-subtitle {
  color: var(--text-tertiary);
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
}

.time-windows-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.5rem;
}

.time-window {
  background: white;
  border-radius: 10px;
  padding: 1.5rem;
  box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
  border-left: 4px solid #4CAF50;
  transition: transform 0.2s;
}

.time-window:hover {
  transform: translateY(-3px);
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
}

.time-window.excellent {
  border-left-color: #4CAF50;
}

.time-window.good {
  border-left-color: #FF9800;
}

.time-window.fair {
  border-left-color: #2196F3;
}

.window-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.window-icon {
  font-size: 1.5rem;
}

.window-name {
  font-weight: bold;
  color: var(--text-primary);
  font-size: 1.1rem;
  flex: 1;
}

.window-badge {
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 600;
}

.window-badge.excellent {
  background: #e8f5e9;
  color: #2e7d32;
}

.window-badge.good {
  background: var(--card-bg)3e0;
  color: #e65100;
}

.window-badge.fair {
  background: #e3f2fd;
  color: #1565c0;
}

.window-time {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: #f5f5f5;
  padding: 0.75rem;
  border-radius: 8px;
  margin-bottom: 1rem;
}

.time-icon {
  font-size: 1.2rem;
}

.time-text {
  font-weight: 600;
  color: #667eea;
  font-size: 1.05rem;
}

.window-description {
  color: var(--text-tertiary);
  line-height: 1.6;
  margin-bottom: 1rem;
  font-size: 0.95rem;
}

.suitable-for {
  background: #f0f4ff;
  padding: 0.75rem;
  border-radius: 6px;
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.suitable-for strong {
  color: #667eea;
  margin-right: 0.5rem;
}

/* Avoid Periods Section */
.avoid-periods-section {
  background: var(--card-bg)3f3;
  border-radius: 12px;
  padding: 1.5rem;
  margin: 2rem 0;
  border: 2px solid #ffcdd2;
}

.avoid-periods-section h4 {
  color: #c62828;
  font-size: 1.3rem;
  margin-bottom: 1rem;
}

.avoid-periods-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.avoid-period {
  background: white;
  border-radius: 8px;
  padding: 1rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
}

.avoid-icon {
  font-size: 1.5rem;
}

.avoid-details {
  display: flex;
  flex-direction: column;
}

.avoid-details strong {
  color: #c62828;
  font-size: 1rem;
  margin-bottom: 0.25rem;
}

.avoid-time {
  color: var(--text-tertiary);
  font-size: 0.9rem;
}

/* Mode Toggle Section */
.mode-toggle-section {
  background: white;
  border-radius: 15px;
  padding: 2rem;
  margin-bottom: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.mode-toggle-section h3 {
  color: #667eea;
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
  text-align: center;
}

.mode-toggle-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1.5rem;
}

.mode-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1.5rem;
  background: #f5f5f5;
  border: 2px solid transparent;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: center;
}

.mode-button:hover {
  border-color: #667eea;
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.2);
}

.mode-button.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-color: #667eea;
  box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
}

.mode-icon {
  font-size: 2.5rem;
  margin-bottom: 0.8rem;
}

.mode-title {
  font-size: 1.2rem;
  font-weight: bold;
  margin-bottom: 0.5rem;
}

.mode-desc {
  font-size: 0.9rem;
  opacity: 0.85;
  line-height: 1.4;
}

.mode-button.active .mode-desc {
  opacity: 0.95;
}

/* Score Display Section */
.score-display-section {
  background: white;
  border-radius: 15px;
  padding: 2.5rem;
  margin-bottom: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.score-display-section h3 {
  color: #667eea;
  font-size: 1.8rem;
  margin-bottom: 2rem;
  text-align: center;
}

.score-content-grid {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 3rem;
  align-items: center;
}

.score-meter-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.score-circle {
  position: relative;
  width: 200px;
  height: 200px;
}

.score-circle-svg {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.score-circle-bg {
  fill: none;
  stroke: var(--neutral-200);
  stroke-width: 12;
}

.score-circle-fill {
  fill: none;
  stroke-width: 12;
  stroke-linecap: round;
  transition: stroke-dasharray 0.6s ease;
}

.score-circle-fill.auspicious {
  stroke: #4CAF50;
}

.score-circle-fill.moderate {
  stroke: #FF9800;
}

.score-circle-fill.avoid {
  stroke: #F44336;
}

.score-text-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.score-number {
  font-size: 3.5rem;
  font-weight: bold;
  color: var(--text-primary);
  line-height: 1;
}

.score-outof {
  font-size: 1.2rem;
  color: var(--text-tertiary);
  margin-top: 0.2rem;
}

.score-status-text {
  font-size: 1.1rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.score-status-text.auspicious {
  color: #4CAF50;
}

.score-status-text.moderate {
  color: #FF9800;
}

.score-status-text.avoid {
  color: #F44336;
}

/* Score Breakdown */
.score-breakdown {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.score-breakdown h4 {
  color: #667eea;
  font-size: 1.3rem;
  margin-bottom: 1rem;
}

.breakdown-bars {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.breakdown-item {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.breakdown-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.breakdown-label {
  font-size: 0.95rem;
  color: var(--text-primary);
  font-weight: 500;
}

.breakdown-points {
  font-size: 1rem;
  font-weight: bold;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  background: var(--neutral-200);
}

.breakdown-points.positive {
  color: #2e7d32;
  background: #e8f5e9;
}

.breakdown-points.negative {
  color: #c62828;
  background: #ffebee;
}

.breakdown-bar-container {
  width: 100%;
  height: 8px;
  background: var(--neutral-200);
  border-radius: 4px;
  overflow: hidden;
}

.breakdown-bar-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.4s ease;
}

/* Responsive Design for Score Display */
@media (max-width: 768px) {
  .score-content-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .mode-toggle-buttons {
    grid-template-columns: 1fr;
  }

  .score-circle {
    width: 180px;
    height: 180px;
  }

  .score-number {
    font-size: 3rem;
  }
}

