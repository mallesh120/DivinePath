@import '../../styles/theme.css';

.dream-interpretation-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #4E54C8 0%, #8F94FB 100%);
}

.dream-header {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  padding: 2rem;
  text-align: center;
  color: white;
}

.dream-header h1 {
  font-size: 2.5rem;
  margin-bottom: 0.5rem;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
}

.dream-subtitle {
  font-size: 1.1rem;
  opacity: 0.95;
  max-width: 800px;
  margin: 0 auto;
}

.dream-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
}

.input-section {
  display: grid;
  gap: 2rem;
}

.dream-input-card {
  background: white;
  border-radius: 20px;
  padding: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.dream-input-card h2 {
  color: #4E54C8;
  font-size: 2rem;
  margin-bottom: 1rem;
}

.input-instruction {
  color: var(--text-tertiary);
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

.dream-textarea {
  width: 100%;
  border: 2px solid #eee;
  border-radius: 15px;
  padding: 1rem;
  font-size: 1rem;
  font-family: inherit;
  resize: vertical;
  transition: border-color 0.3s ease;
  margin-bottom: 1.5rem;
}

.dream-textarea:focus {
  outline: none;
  border-color: #4E54C8;
}

.analyze-btn {
  width: 100%;
  padding: 1.2rem;
  background: linear-gradient(135deg, #4E54C8 0%, #8F94FB 100%);
  color: white;
  border: none;
  border-radius: 15px;
  font-size: 1.2rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.analyze-btn:hover:not(:disabled) {
  transform: scale(1.02);
  box-shadow: 0 5px 15px rgba(78, 84, 200, 0.4);
}

.analyze-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.common-symbols-section {
  background: white;
  border-radius: 20px;
  padding: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.common-symbols-section h3 {
  color: #4E54C8;
  font-size: 1.8rem;
  margin-bottom: 0.5rem;
}

.common-symbols-section > p {
  color: var(--text-tertiary);
  margin-bottom: 1.5rem;
}

.symbols-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
}

.symbol-card {
  background: #f9f9f9;
  border: 2px solid #eee;
  border-radius: 12px;
  padding: 1rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s ease;
}

.symbol-card:hover {
  background: white;
  border-color: #4E54C8;
  transform: translateY(-5px);
  box-shadow: 0 5px 15px rgba(78, 84, 200, 0.2);
}

.symbol-icon {
  font-size: 3rem;
  margin-bottom: 0.5rem;
}

.symbol-name {
  color: #4E54C8;
  font-weight: 600;
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
}

.symbol-meaning {
  color: var(--text-tertiary);
  font-size: 0.85rem;
  line-height: 1.4;
}

.interpretation-section {
  background: white;
  border-radius: 20px;
  padding: 2rem;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.interpretation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  padding-bottom: 1rem;
  border-bottom: 2px solid #eee;
}

.interpretation-header h2 {
  color: #4E54C8;
  font-size: 2rem;
}

.new-dream-btn {
  background: linear-gradient(135deg, #4E54C8 0%, #8F94FB 100%);
  color: white;
  border: none;
  padding: 0.8rem 1.5rem;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.new-dream-btn:hover {
  transform: scale(1.05);
}

.interpretation-content {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.interpretation-card {
  background: #f9f9f9;
  border-radius: 15px;
  padding: 1.5rem;
  border-left: 4px solid #4E54C8;
}

.interpretation-card h3 {
  color: #4E54C8;
  font-size: 1.4rem;
  margin-bottom: 1rem;
}

.interpretation-card p {
  color: var(--text-tertiary);
  line-height: 1.8;
}

.main-interpretation {
  background: linear-gradient(135deg, #4E54C820 0%, #8F94FB20 100%);
}

.spiritual-significance {
  border-left-color: #FF9800;
}

.spiritual-significance h3 {
  color: #FF9800;
}

.scripture-reference {
  border-left-color: #4CAF50;
  background: #f0f8f4;
}

.scripture-reference h3 {
  color: #4CAF50;
}

.found-symbols {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.found-symbol {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: white;
  padding: 1rem;
  border-radius: 10px;
}

.found-symbol-icon {
  font-size: 3rem;
}

.found-symbol strong {
  color: #4E54C8;
  display: block;
  margin-bottom: 0.3rem;
}

.found-symbol p {
  color: var(--text-tertiary);
  font-size: 0.95rem;
  margin: 0;
}

.recommendations ul {
  list-style: none;
  padding: 0;
}

.recommendations li {
  color: var(--text-tertiary);
  padding: 0.8rem;
  background: white;
  border-radius: 8px;
  margin-bottom: 0.8rem;
  padding-left: 2rem;
  position: relative;
}

.recommendations li::before {
  content: '🙏';
  position: absolute;
  left: 0.5rem;
}

.dream-journal-tip {
  background: linear-gradient(135deg, #FFD54F 0%, #FFC107 100%);
  border-radius: 15px;
  padding: 1.5rem;
  margin-top: 1rem;
}

.dream-journal-tip h4 {
  color: #F57C00;
  font-size: 1.2rem;
  margin-bottom: 0.8rem;
}

.dream-journal-tip p {
  color: #5D4037;
  line-height: 1.6;
  margin: 0;
}

@media (max-width: 768px) {
  .dream-header h1 {
    font-size: 2rem;
  }

  .symbols-grid {
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  }

  .interpretation-header {
    flex-direction: column;
    gap: 1rem;
    align-items: stretch;
  }

  .new-dream-btn {
    width: 100%;
  }

  .found-symbol {
    flex-direction: column;
    text-align: center;
  }
}
