@import '../../styles/theme.css';

.home-page {
  min-height: 100vh;
  padding: 2rem;
  background: linear-gradient(135deg, #fffaf0 0%, #fff4e6 100%);
}

.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--warm-cream) 0%, var(--parchment-light) 50%, var(--parchment-mid) 100%);
}

.devotional-hero {
  background: linear-gradient(135deg, var(--saffron-primary) 0%, var(--saffron-light) 100%);
  padding: 60px 20px;
  text-align: center;
  box-shadow: 0 8px 24px var(--accent-glow);
  margin-bottom: 40px;
}

.hero-content {
  max-width: 800px;
  margin: 0 auto;
}

.hero-title {
  font-family: 'Playfair Display', 'Cinzel', serif;
  font-size: 3.2rem;
  font-weight: 800;
  color: white;
  margin: 0 0 15px 0;
  text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.28);
  letter-spacing: -1px;
}

.hero-subtitle {
  font-size: 1.3rem;
  color: rgba(255, 255, 255, 0.95);
  margin: 0 0 20px 0;
  line-height: 1.6;
}

.hero-date {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  background: rgba(255, 255, 255, 0.2);
  padding: 10px 25px;
  border-radius: 25px;
  display: inline-block;
  margin-top: 10px;
}

.devotional-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px 60px 20px;
}

.devotional-section {
  margin-bottom: 40px;
  animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.practice-tips-widget {
  background: linear-gradient(135deg, #ffffff 0%, #faf9f7 100%);
  padding: 40px;
  border-radius: 20px;
  box-shadow: 0 8px 32px var(--shadow-light);
  border: 2px solid var(--border-subtle);
}

.tips-title {
  font-family: 'Playfair Display', 'Cinzel', serif;
  font-size: 2.2rem;
  font-weight: 700;
  background: linear-gradient(135deg, var(--saffron-primary), var(--text-primary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-align: center;
  margin: 0 0 40px 0;
}

.tips-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
}

.tip-card {
  background: white;
  padding: 25px;
  border-radius: 15px;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.tip-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  border-color: rgba(255, 102, 0, 0.3);
}

.tip-icon {
  font-size: 3rem;
  display: block;
  text-align: center;
  margin-bottom: 15px;
}

.tip-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin: 0 0 20px 0;
}

.tip-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.tip-list li {
  padding: 10px 0 10px 30px;
  position: relative;
  font-size: 0.95rem;
  color: #555;
  line-height: 1.6;
}

.tip-list li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: var(--saffron-primary);
  font-weight: bold;
  font-size: 1.1rem;
}

/* Tablet Responsive */
@media (max-width: 1024px) {
  .tips-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Mobile Responsive */
@media (max-width: 768px) {
  .devotional-hero {
    padding: 40px 20px;
  }

  .hero-title {
    font-size: 2rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
  }

  .hero-date {
    font-size: 0.95rem;
  }

  .devotional-container {
    padding: 0 15px 40px 15px;
  }

  .practice-tips-widget {
    padding: 25px 20px;
  }

  .tips-title {
    font-size: 1.5rem;
  }

  .tips-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .tip-card {
    padding: 20px;
  }
}

/* Smooth scrolling for the page */
html {
  scroll-behavior: smooth;
}

/* Custom scrollbar for the page */
::-webkit-scrollbar {
  width: 10px;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(to bottom, #ff6600, #ff8833);
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(to bottom, #ff5500, #ff7722);
}
