{
  "name": "divine-path",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@ishubhamx/panchangam-js": "github:mallesh120/Hindu-Panchangam#main",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "astronomy-engine": "^2.1.19",
    "node-fetch": "^2.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^6.22.3",
    "react-scripts": "5.0.1",
    "react-transition-group": "^4.4.5",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.9.7",
    "playwright": "^1.57.0"
  },
  "scripts": {
    "start": "node scripts/strip-sourcemaps.js && rm -rf node_modules/.cache && react-scripts start",
    "build": "node scripts/strip-sourcemaps.js && rm -rf node_modules/.cache && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "generate-mantras": "node scripts/generate-mantras.js",
    "lint": "eslint src --ext .js,.jsx --max-warnings=10",
    "lint:fix": "eslint src --ext .js,.jsx --fix --max-warnings=10",
    "pre-push": "npm run lint && npm run build",
    "test-playwright": "node scripts/test-playwright-setup.js",
    "scrape-batch": "node scripts/batch-scrape-playwright.js",
    "scrape-universal": "node scripts/scrape-universal.js"
  },
  "postinstall": "node scripts/strip-sourcemaps.js",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
